PORT=3000
NODE_ENV=development

# Local Postgres (works with Docker or local install)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/velore_db?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5433/velore_db?schema=public"

# Auth
JWT_SECRET="change_this_local_dev_secret"
JWT_EXPIRES_IN="7d"

# Allowed frontend origin (CORS)
FRONTEND_URL="http://localhost:5173"

# AI microservice (optional)
AI_SERVICE_URL="http://localhost:5001"

# Payments (optional)
STRIPE_SECRET_KEY=""

# Email (optional)
GMAIL_USER=""
GMAIL_APP_PASSWORD=""